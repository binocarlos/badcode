{
  "name": "@badcode/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "badcode — CLI for preparing Gemini prompts and managing comic assets in GCS.",
  "bin": {
    "badcode": "./src/bin.ts"
  },
  "scripts": {
    "badcode": "tsx src/bin.ts",
