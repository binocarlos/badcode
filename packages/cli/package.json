    "@badcode/comic-meta": "*",
    "commander": "^12.1.0",
    "sharp": "^0.33.5",
    "thumbhash": "^0.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
